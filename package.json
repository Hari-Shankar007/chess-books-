{
  "name": "chess-library",
  "version": "1.0.0",
  "description": "Offline Chess Book Library Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.educhess.library",
    "productName": "Chess Book Library",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "directories": {        "buildResources": "build",
        "output": "dist"
      }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
